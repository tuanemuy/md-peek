{
  "name": "markdown-peek",
  "version": "1.1.2",
  "description": "Markdown preview CLI with live reload",
  "type": "module",
  "bin": {
    "peek": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev:css": "postcss src/styles/global.css -o src/renderer/global.css --watch",
    "dev:server": "tsx --import ./src/loaders/css.mjs src/index.ts",
    "dev": "pnpm run \"/^dev:.*/\"",
    "pretest": "postcss src/styles/global.css -o src/renderer/global.css && node scripts/build-client.mjs",
    "build:css": "postcss src/styles/global.css -o src/renderer/global.css --env production",
    "build:client": "node scripts/build-client.mjs",
    "build": "pnpm build:css && pnpm build:client && tsdown",
    "start": "node dist/index.js",
    "lint": "biome lint",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "typecheck": "tsgo",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "markdown",
    "preview",
    "cli",
    "live-reload"
  ],
  "author": "Hikaru Otabe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuanemuy/markdown-peek.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@hono/node-server": "^1.14.1",
    "@mdit/plugin-tasklist": "^0.23.1",
    "@shikijs/markdown-it": "^4.0.1",
    "gunshi": "^0.29.2",
    "hono": "^4.7.7",
    "ignore": "^7.0.5",
    "markdown-it": "^14.1.1",
    "markdown-it-async": "^2.2.0",
    "picocolors": "^1.1.1",
    "shiki": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.3",
    "@typescript/native-preview": "7.0.0-dev.20260228.1",
    "esbuild": "^0.27.3",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.1.4",
    "tsdown": "^0.12.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
